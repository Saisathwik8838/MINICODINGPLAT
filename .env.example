# ============================================
# PRODUCTION CONFIGURATION TEMPLATE
# ============================================
# IMPORTANT: Create a .env file based on this template
# NEVER commit .env to version control!

# ============================================
# Core Configuration
# ============================================
NODE_ENV=production
PORT=5000

# ============================================
# SECURITY: Generate strong secrets in production!
# Generate with: openssl rand -base64 32
# ============================================
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d
METRICS_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/minileetcode?schema=public

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# API Configuration
# ============================================
FRONTEND_URL=http://localhost
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Submission Constraints
# ============================================
MAX_CODE_SIZE_KB=100
SUBMISSION_TIMEOUT_SECONDS=30
QUEUE_NAME=submission-queue
WORKER_CONCURRENCY=5

# ============================================
# Docker
# ============================================
DOCKER_VOLUME_NAME=minicodingplat_minileetcode-tmp
